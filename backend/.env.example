# ============================================================
# ResearchGPT Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME=ResearchGPT
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api

# --- Security ---
# Generate with: openssl rand -hex 32
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# --- Database ---
DATABASE_URL=
# For sync (alembic): use postgresql://...
SYNC_DATABASE_URL=
GEMINI_MODEL=gemini-2.5-flash

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION_NAME=research_papers

# --- Storage ---
PDF_STORAGE_DIR=./storage/pdfs
MAX_PDF_SIZE_MB=50

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Rate Limiting ---
MAX_PAPERS_PER_SEARCH=20
MAX_PAPERS_TO_DOWNLOAD=10

# --- Future: AWS S3 ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=researchgpt-pdfs
# USE_S3=false

# --- Future: Pinecone ---
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=
# PINECONE_INDEX_NAME=researchgpt
# USE_PINECONE=false

# --- Redis (for Celery task queue) ---
REDIS_URL=redis://localhost:6379/0
